<PetalProWeb.DevLayoutComponent.dev_layout
  current_page={:dev_sent_emails}
  current_user={@current_user}
>
  <div class="bg-white">
    <.alert
      color="info"
      with_icon
      label={gettext("To see emails here, you must perform an action e.g change email")}
    />
    <iframe class="h-screen w-full overflow-auto px-12 pt-10" src="/dev/mailbox"></iframe>
  </div>
</PetalProWeb.DevLayoutComponent.dev_layout>
